{
  "type": "kafka",
  "spec": {
    "dataSchema": {
      "dataSource": "tweets-kafka",
      "timestampSpec": {
        "column": "timestamp",
        "format": "auto"
      },
      "dimensionsSpec": {
        "dimensions": [
          { "type": "long", "name": "user_id" },
          { "type": "string", "name": "tweet" }
        ]
      },
      "granularitySpec": {
        "type": "uniform",
        "segmentGranularity": "HOUR",
        "queryGranularity": "none",
        "rollup": false
      }
    },
    "ioConfig": {
      "topic": "tweets-kafka",
      "inputFormat": {
        "type": "json"
      },
      "replicas": 1,
      "taskCount": 1,
      "taskDuration": "PT3600S",
      "consumerProperties": {
        "bootstrap.servers": "kafka:9092"
      },
      "useEarliestOffset": true
    },
    "tuningConfig": {
      "type": "kafka"
    }
  }
}
